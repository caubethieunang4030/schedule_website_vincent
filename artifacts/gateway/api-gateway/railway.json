{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "installCommand": "pnpm install --no-frozen-lockfile",
    "buildCommand": "pnpm --filter @workspace/api-gateway build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @workspace/api-gateway start"
  }
}
