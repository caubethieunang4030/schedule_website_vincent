{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "echo \"Skipping preinstall\"",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "dev:services": "pnpm --filter @workspace/api-gateway --filter @workspace/*-service --parallel run dev",
    "dev:frontend": "pnpm --filter @workspace/summit run dev",
    "dev": "pnpm --filter @workspace/api-gateway --filter @workspace/*-service --filter @workspace/summit --parallel run dev"
  },
  "private": true,
  "devDependencies": {
    "@esbuild/darwin-arm64": "^0.27.3",
    "@rollup/rollup-darwin-arm64": "^4.61.1",
    "@tailwindcss/oxide-darwin-arm64": "^4.3.0",
    "lightningcss-darwin-arm64": "^1.32.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
